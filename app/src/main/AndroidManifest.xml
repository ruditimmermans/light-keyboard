<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Voice dictation (optional): download the offline model, then record for on-device STT. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Package visibility (Android 11+) for speech recognizer components. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LightKeyboard">

        <!-- The system keyboard (IME). Once enabled + selected, it appears in every text field. -->
        <service
            android:name=".LightImeService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Transparent shim: requests RECORD_AUDIO on the IME's behalf (an IME can't ask directly). -->
        <activity
            android:name=".MicPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Tiny launcher screen: a one-tap path to enable/select the keyboard. -->
        <activity
            android:name=".SetupActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Keyboard layout picker (QWERTY / AZERTY / QWERTZ), opened from setup. -->
        <activity
            android:name=".KeyboardLayoutActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Keyboard height picker, opened from setup. -->
        <activity
            android:name=".KeyboardHeightActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
    </application>
</manifest>
